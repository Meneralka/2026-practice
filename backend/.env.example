########################################################################
# document-service local dev environment - environment variables
#
# Copy this file to `.env` (same directory) before running
# `docker compose up -d`. Docker Compose automatically loads `.env`.
#
#   cp .env.example .env
#
# All values below are throw-away dev defaults. Do NOT reuse them
# anywhere outside a local machine.
########################################################################

# ---------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------
POSTGRES_DB=documentservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# ---------------------------------------------------------------------
# Kafka (KRaft mode, single-node, no Zookeeper)
# ---------------------------------------------------------------------
# Port the broker publishes for host access (Spring Boot app running on
# the host machine connects here via localhost:${KAFKA_HOST_PORT}).
KAFKA_HOST_PORT=9092
# Internal port other containers on the compose network use
# (bootstrap servers value from inside a container: kafka:29092).
KAFKA_INTERNAL_PORT=29092
KAFKA_CLUSTER_ID=MzVkNzEyOTMtOTk5OS00ZTli
# Kafka UI web console (http://localhost:${KAFKA_UI_PORT})
KAFKA_UI_PORT=8081

# ---------------------------------------------------------------------
# Object storage
# ---------------------------------------------------------------------
# Which object-storage backend to actually start:
#   rustfs -> apache-2.0 S3-compatible store, candidate under evaluation
#             (see backend/tasks item 3 - RustFS feature check, pending)
#   minio  -> proven, mature fallback if RustFS fails the evaluation
# Selects the compose profile enabled by default (see docker-compose.yml).
COMPOSE_PROFILES=rustfs

# Shared by both rustfs and minio services below (S3 root credentials).
OBJECT_STORAGE_ROOT_USER=devadmin
OBJECT_STORAGE_ROOT_PASSWORD=devadmin123
OBJECT_STORAGE_API_PORT=9000
OBJECT_STORAGE_CONSOLE_PORT=9001

# ---------------------------------------------------------------------
# ClamAV
# ---------------------------------------------------------------------
CLAMAV_PORT=3310
